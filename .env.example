# ==============================================================================
# TANGLEWEAVE STUDIOS - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ==============================================================================
# POSTGRESQL
# ==============================================================================
POSTGRES_PASSWORD=change_me_use_strong_random_string_at_least_32_chars

# ==============================================================================
# RAUTHY (OIDC Provider) - Bootstrapping
# ==============================================================================
# Uses LOCAL_TEST=true for development
# Bootstrapping: Creates admin user and API key on first run (clean DB only)
# Admin credentials: admin@localhost.de / BOOTSTRAP_ADMIN_PASSWORD_PLAIN
BOOTSTRAP_ADMIN_PASSWORD_PLAIN=MySuperSafePassword123!
# API Key secret (MUST be 64+ characters for security)
BOOTSTRAP_API_KEY_SECRET=TwUA2M7RZ8H3FyJHbti2AcMADPDCxDqUKbvi8FDnm3nYidwQx57Wfv6iaVTQynMh
# API Key with full permissions (Base64 encoded JSON)
# Decoded: {"name":"bootstrap","access":[{"group":"Clients","access_rights":["read","create","update","delete"]},{"group":"Roles","access_rights":["read","create","update","delete"]}]}
BOOTSTRAP_API_KEY=eyJuYW1lIjoiYm9vdHN0cmFwIiwiYWNjZXNzIjpbeyJncm91cCI6IkNsaWVudHMiLCJhY2Nlc3NfcmlnaHRzIjpbInJlYWQiLCJjcmVhdGUiLCJ1cGRhdGUiLCJkZWxldGUiXX0seyJncm91cCI6IlJvbGVzIiwiYWNjZXNzX3JpZ2h0cyI6WyJyZWFkIiwiY3JlYXRlIiwidXBkYXRlIiwiZGVsZXRlIl19XX0=

# ==============================================================================
# NAKAMA (Game Server)
# ==============================================================================
# Get license from https://heroiclabs.com/ (required for production)
NAKAMA_LICENSE_KEY=
NAKAMA_API_KEY=change_me_use_strong_random_string_for_s2s

# Rauthy OIDC Integration
RAUTHY_ISSUER=https://tangleweave_rauthy:8443
RAUTHY_JWKS_URL=https://tangleweave_rauthy:8443/auth/v1/oidc/certs
RAUTHY_CLIENT_ID=unwind-game

# ==============================================================================
# APTABASE (Analytics)
# ==============================================================================
APABASE_JWT_SECRET=change_me_use_64_char_random_string_here_for_production
APABASE_DATABASE_URL=postgresql://tangleweave:${POSTGRES_PASSWORD}@db:5432/aptabase_db

# ==============================================================================
# BACKOFFICE API
# ==============================================================================
BACKOFFICE_ADMIN_KEY=change_me_use_strong_random_string_for_admin_access
BACKOFFICE_DATABASE_URL=postgresql://tangleweave:${POSTGRES_PASSWORD}@db:5432/backoffice_db
OIDC_ISSUER=https://tangleweave_rauthy:8443
JWKS_URL=https://tangleweave_rauthy:8443/auth/v1/oidc/certs
OIDC_CLIENT_ID=backoffice-api
OIDC_REDIRECT_URI=http://localhost/callback
NAKAMA_URL=http://nakama:7350

# ==============================================================================
# PAYMENT WEBHOOKS
# ==============================================================================
# HMAC secret for verifying payment provider webhooks
# Generate with: openssl rand -hex 32
PAYMENT_WEBHOOK_SECRET=change_me_generate_with_openssl_rand_hex_32

# ==============================================================================
# CLOUDFLARE TUNNEL (Production only)
# ==============================================================================
# Get token from https://dash.cloudflare.com/
# Only needed for production deployment
CF_TUNNEL_TOKEN=
