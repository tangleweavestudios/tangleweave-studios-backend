# ==============================================================================
# TANGLEWEAVE STUDIOS - ENVIRONMENT TEMPLATE
# ==============================================================================
# ВАЖНО: Скопируйте этот файл в .env для локальной разработки.
# Для Test/Prod окружений скопируйте значения отсюда в GitHub Secrets.
# НИКОГДА не коммитьте файлы .env, .env.prod или .env.test в Git!
# ==============================================================================

APP_ENV=local

# ==============================================================================
# 1. БАЗЫ ДАННЫХ (POSTGRESQL)
# ==============================================================================
# Главный пароль суперпользователя базы
POSTGRES_PASSWORD=change_me_super_secret_pg_password
# Пароли для конкретных баз данных сервисов
RAUTHY_DB_PASSWORD=change_me_rauthy_db_pass
NAKAMA_DB_PASSWORD=change_me_nakama_db_pass
APTABASE_DB_PASSWORD=change_me_aptabase_db_pass
BACKOFFICE_DB_PASSWORD=change_me_backoffice_db_pass

# ==============================================================================
# 2. RAUTHY (АВТОРИЗАЦИЯ И SSO)
# ==============================================================================
# Пароль администратора (используется только при первой инициализации чистой базы)
# Логин по умолчанию: admin@localhost.de
BOOTSTRAP_ADMIN_PASSWORD_PLAIN=MySuperSafePassword123!

# Настройки SMTP (По умолчанию настроено на локальный Mailcrab для тестов)
SMTP_URL=mailcrab
SMTP_PORT=1025
SMTP_USERNAME=mailcrab
SMTP_PASSWORD=mailcrab
SMTP_FROM=auth@tangleweavestudios.com
SMTP_DANGER_INSECURE=true

# ==============================================================================
# 3. NAKAMA (ИГРОВОЙ СЕРВЕР UNWIND)
# ==============================================================================
# Лицензионный ключ (оставьте пустым для локальной разработки/тестов)
NAKAMA_LICENSE_KEY=
# Ключ для Server-to-Server запросов (из Backoffice API в Nakama)
NAKAMA_API_KEY=change_me_strong_s2s_key

# Связка Nakama с Rauthy
# Локально: https://localhost:8443 (или имя контейнера tangleweave_rauthy:8443)
# Прод: https://auth.tangleweavestudios.com
RAUTHY_ISSUER=https://tangleweave_rauthy:8443
RAUTHY_JWKS_URL=https://auth.tangleweave.local/auth/v1/oidc/certs
RAUTHY_CLIENT_ID=unwind-game

# ==============================================================================
# 4. BACKOFFICE API (RUST MICROSERVICE)
# ==============================================================================
# Ключ для экстренного админского доступа к API
BACKOFFICE_ADMIN_KEY=change_me_admin_master_key
# Секрет для проверки вебхуков от платежных систем (генерация: openssl rand -hex 32)
PAYMENT_WEBHOOK_SECRET=change_me_payment_webhook_secret

# Связка API с Rauthy
OIDC_ISSUER=https://auth.tangleweave.local/auth/v1/
JWKS_URL=https://tangleweave_rauthy:8443/auth/v1/oidc/certs
OIDC_CLIENT_ID=backoffice-api

# ==============================================================================
# 5. BACKOFFICE FRONTEND (REACT SPA)
# ==============================================================================
# Внешний URL авторизации (то, что видит браузер)
# Локально: https://localhost/auth/v1
# Прод: https://auth.tangleweavestudios.com/auth/v1
VITE_OIDC_AUTHORITY=https://auth.tangleweave.local/auth/v1
VITE_OIDC_CLIENT_ID=backoffice-admin

# ==============================================================================
# 6. APTABASE (АНАЛИТИКА)
# ==============================================================================
# Секретный ключ для подписи токенов аналитики (64+ символа)
APABASE_AUTH_SECRET=change_me_use_64_char_random_string_here_for_production
# Базовый URL для CORS (откуда разрешено слать аналитику)
APTABASE_BASE_URL=http://localhost:3000

# ==============================================================================
# 7. NGINX & ЛОКАЛЬНЫЕ ПОРТЫ
# ==============================================================================
# Локально ставьте 80 и 443. 
# На NAS для Test/Prod задайте другие порты (например, 8080/8443), 
# чтобы не конфликтовать с портами самой ОС DSM Synology.
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Порт для веб-интерфейса Mailcrab (перехват писем локально)
MAILCRAB_PORT=1080

# ==============================================================================
# 8. CLOUDFLARE TUNNEL
# ==============================================================================
# Токен из дашборда Cloudflare.
# Нужен только для профиля --profile cloudflare на сервере NAS.
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Идентификатор клиента в админке Rauthy
OAUTH2_PROXY_CLIENT_ID=tangleweave-internal
# Секретный ключ (создается в Rauthy)
OAUTH2_PROXY_CLIENT_SECRET=qVFuAzBmUgPADxujeOZePCxXzRFieNvptNnEmYHEYsUmcdGAePOigMyWJnZuwkfN
# Секрет для подписи куки (генерация: openssl rand -base64 32 | head -c 32 | base64)
OAUTH2_PROXY_COOKIE_SECRET=v7zR9kP4mX2wA5cT8bN1qY6eS3hV0gD7jL4fU2xR9sM=
# Домен, для которого будут действовать куки.
# Локально: .localhost
# Прод: .tangleweavestudios.com
OAUTH2_PROXY_COOKIE_DOMAIN=.tangleweave.local